---
import type { Plan } from '../types';

interface Props {
    plan: Plan;
}
const { key, title, heroImage, place, date, startTime, capacity, label, dateTbd } = Astro.props.plan;
const thisYear = new Date().getFullYear();
const year = date.getFullYear();
// const yearText = thisYear === year ? '' : `${year}`;
const monthText = String(date.getMonth() + 1).padStart(2, '0');
const thisYearClass= thisYear === year ? ' this-year' : '';
const dayText = String(date.getDate()).padStart(2, '0');
const weekText = ['日', '月', '火', '水', '木', '金', '土'][date.getDay()];
---
<a class={`plan rough-frame${thisYearClass}`} href={`/events/${key}/`} data-rough-bleed="7">
  <div class="image-wrapper">
      <img src={heroImage} alt={title}>
  </div>
  <div class="plan-content">
    {
        dateTbd && <div class="date">未定</div>
    }
    {
        !dateTbd &&
        <div class="date">
          <div class="date-year">{year}</div>
          <div class="date-month">{monthText}</div>
          <div class="date-deli">/</div>
          <div class="date-day">{dayText}</div>
          <div class="date-week">({weekText})</div>
        </div>
      }
      <div class="plan-desc">
          <div class="plan-hour">{startTime}</div>
          <div class="plan-place">{place}</div>
          <div class="plan-title">{title}</div>
          <div class="plan-capacity">{capacity}</div>
      </div>
  </div>
  {
    label && <div class="plan-label">{label}</div>
  }
</a>
<style>
.plan {
    color: #222222;
    text-decoration: none;
    background-color: rgba(255, 255, 255, 0.92);
    width: 100%;
            border: 0;
            border-radius: 0;
            box-shadow: none;
            position: relative;
            transition: background-color 120ms ease, transform 120ms ease;
        }
        .plan:hover {
            background-color: #ffffff;
        }
        .plan > * {
            position: relative;
            z-index: 1;
        }
        @media (min-width: 480px) {
          .plan {
            width: 400px;
          }
        }
        @media (min-width: 720px) {
          .plan {
            width: 340px;
          }
        }
        .plan .image-wrapper {
            padding: 1px 1px 0;
        }
        .plan img {
            width: 100%;
            height: 120px;
            object-fit: cover;
            display: block;
            transform-origin: center center;
        }
        .plan .plan-content {
            padding: 10px 12px 14px;
            display: flex;
        }
        .plan .date {
            width: 56px;
            display: flex;
            flex-direction: column;
            align-items: center;
            font-size: 1rem;
            flex-shrink: 0;
            box-sizing: border-box;
            padding: 0 6px;
        }
        .plan.this-year .date {
            font-size: 1.2rem;
            padding: 0;
        }
        .plan.this-year .date-year {
            display: none;
        }
        .plan .date-year {
            font-size: .8rem;
            color: #444444;
        }
        .plan .date-month {
            align-self: start;
        }
        .plan .date-deli {
            font-size: 1rem;
            transform: rotate(20deg);
            margin: -1rem 1rem -1rem 1rem;
        }
        .plan.this-year .date-deli {
            font-size: 2rem;
            margin: -1.5rem 0 -1.5rem 0;
        }
        .plan .date-day {
            align-self: end
        }
        .plan .date-week {
            margin-top: -2px;
        }
        .plan .plan-desc {
            padding: 0 0 0 20px;
            display: flex;
            flex-direction: column;
            flex-grow: 1;
        }
        .plan .plan-hour {
            font-size: .8rem;
            font-weight: 600;
        }
        .plan .plan-place {
            font-size: .8rem;
            color: #444444;
        }
        .plan .plan-title {
            font-weight: 600;
            margin-top: 4px;
        }
        .plan .plan-capacity {
            margin-top: 4px;
            font-size: 1.2rem;
            color: #333333;
            text-align: right;
            min-width: 20px;
            min-height: 1.4rem;
        }
        .plan .plan-label {
            position: absolute;
            bottom: 0;
            left: 4px;
            color: #111111;
            padding: 4px;
            font-size: 1.2rem;
            font-weight: bold;
            transform: rotate(-4deg);
        }
</style>
