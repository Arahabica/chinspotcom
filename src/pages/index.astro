---
import PlanCard from '../components/PlanCard.astro';
import IndexHead from '../components/IndexHead.astro';
import { getCollection } from 'astro:content';
import { getMidnight, japanDate } from '../lib/DateUtil';
import ProfileCard from '../components/ProfileCard.astro';

const midnight = getMidnight(new Date());

const plans = (await getCollection('blog'));
const futurePlans = plans
  .filter(
    (plan) =>(
      japanDate(plan.data.date).getTime() >= midnight.getTime() && 
      !plan.data.hiddenAtTop
    )
  )
  .sort(
	  (a, b) => a.data.date.valueOf() - b.data.date.valueOf()
  );
const pastPlans = plans
  .filter(
    (plan) => (
      japanDate(plan.data.date).getTime() < midnight.getTime() &&
      !plan.data.hiddenAtTop
    )
  )
  .sort(
	  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
  );
const title = "珍スポ研究室";
const description = "珍スポ研究室とは、珍スポット（B級スポット）が好きな人たちが集まるコミュニティです。\n主にLINEオープンチャットで活動しています。";
const image = "/images/chin.png";
---

<!DOCTYPE html>
<html lang="ja">
<head>
    <IndexHead
      title={title}
      description={description}
      image={image}
    />
    <link rel="prefetch" href="/fonts/YujiSyuku-Regular.css" as="style" />
    <link
      rel="preload"
      href="/fonts/font-subsets/YujiSyuku-Regular-subset-dea5b5271574f50192b69bbe7093ac5f.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="prefetch"
      href="/fonts/font-subsets/YujiSyuku-Regular-subset-1dea4e1a5d3a82a6f26403892643f89b.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href="/fonts/YujiSyuku-Regular.css" />
    <style>
        @font-face {
            font-family: "YujiSyukuTitle";
            src: url("/fonts/font-subsets/YujiSyuku-Regular-subset-dea5b5271574f50192b69bbe7093ac5f.woff2") format("woff2");
            font-display: block;
            unicode-range: U+30b9, U+30dd, U+5ba4, U+73cd, U+7814, U+7a76;
        }
        html,
        body {
            margin: 0;
            padding: 0;
        }
        html {
            /* background: #f6f6f2; */
            background: #f9f9f5;
        }
        p {
            margin: 0;
        }
        body {
            color: #111111;
            font-family: "YujiSyuku-Regular", "Hiragino Mincho ProN", "Yu Mincho", serif;
            line-height: 1.7;
            position: relative;
            background: #f9f9f5;
            overflow-x: hidden;
        }
        .paper-marks {
            position: absolute;
            inset: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }
        body > :not(.paper-marks):not(script) {
            position: relative;
            z-index: 1;
        }
        section {
          padding: 12px;
          margin: 0 auto;
        }
        #greeting {
            /* padding: 28px 12px 12px; */
            margin: 0 auto;
        }
        #greeting h1 {
            display: inline-block;
            color: #111111;
            font-family: "YujiSyukuTitle", "YujiSyuku-Regular", "Hiragino Mincho ProN", "Yu Mincho", serif;
            font-size: 3rem;
            font-weight: 400;
            line-height: 1;
            margin: 0 0 24px;
            text-align: left;
        }
        #greeting .description {
            color: #111111;
            position: relative;
            transform: rotate(0.35deg);
            margin: 36px 0 12px 0;
        }
        .rough-frame {
            border: 0;
            border-radius: 0;
            box-shadow: none;
            box-sizing: border-box;
            position: relative;
        }
        .rough-frame > *:not(.rough-frame-svg) {
            position: relative;
            z-index: 1;
        }
        .sns-list {
          display: flex;
          flex-direction: column;
          width: 100%;
          margin: 0 auto;
          gap: 22px;
        }

        @media (min-width: 1076px) {
          .sns-list {
            flex-direction: row;
            flex-wrap: wrap;
          }
        }
        .sns-button {
            display: flex;
            max-width: 100%;
            min-height: 72px;
            padding: 14px 16px;
            text-decoration: none;
            align-items: center;
            color: #111111;
            background: rgba(255, 255, 255, 0.9);
            transition: background-color 120ms ease, transform 120ms ease;
        }
        .sns-button:hover {
            background: #ffffff;
        }
        .sns-button:nth-child(4n + 1) {
            transform: rotate(-0.35deg);
        }
        .sns-button:nth-child(4n + 2) {
            transform: rotate(0.28deg);
        }
        .sns-button:nth-child(4n + 3) {
            transform: rotate(-0.14deg);
        }
        .sns-button:nth-child(4n) {
            transform: rotate(0.42deg);
        }
        .sns-button:hover {
            transform: translateY(-1px) rotate(0deg);
        }
        .line-button,
        .x-button,
        .instagram-button,
        .mixi2-button {
            color: #111111;
            background: rgba(255, 255, 255, 0.9);
        }
        @media (min-width: 1076px) {
          .sns-button {
            width: 482px;
          }
        }
        .sns-button img {
          width: 48px;
          height: 48px;
          flex: 0 0 auto;
          margin-right: 12px;
          transform-origin: center center;
        }
        .sns-title {
          font-weight: 800;
        }
        .sns-content {
          height: 100%;
        }
        section h2 {
            display: inline-block;
            color: #111111;
            font-size: 1.7rem;
            font-weight: 900;
            line-height: 1.2;
            margin: 28px 0 18px;
            position: relative;
            transform: rotate(-0.6deg);
        }
        .events-section {
            padding: 4px;
            margin: 0 auto;
        }
        @media (min-width: 320px) {
          .events-section {
            padding: 12px;
          }
        }
        @media (min-width: 424px) {
          #greeting {
            width: 400px;
          }
          .events-section {
            width: 400px;
          }
          section {
            width: 400px;
          }
        }
        @media (min-width: 720px) {
          #greeting {
            width: 696px;
          }
          #greeting h1 {
            font-size: 5.4rem;
          }
          .events-section {
            padding: 12px;
            width: 696px;
            margin: 0 auto;
          }
          section {
            width: 696px;
          }
        }
        @media (min-width: 1076px) {
          #greeting {
            width: 1052px;
          }
          #greeting h1 {
            font-size: 6.2rem;
          }
          .events-section {
            padding: 12px;
            width: 1052px;
            margin: 0 auto;
          }
          section {
            width: 1052px;
          }
        }
        .event-list {
            display: flex;
            flex-wrap: wrap;
            gap: 24px 16px;
            align-items: flex-start;
        }
        .event-list :global(.plan:nth-child(5n + 1)) {
            transform: rotate(-0.35deg);
        }
        .event-list :global(.plan:nth-child(5n + 2)) {
            transform: rotate(0.28deg);
        }
        .event-list :global(.plan:nth-child(5n + 3)) {
            transform: rotate(-0.18deg);
        }
        .event-list :global(.plan:nth-child(5n + 4)) {
            transform: rotate(0.42deg);
        }
        .empty-events {
            color: #111111;
            font-size: 2rem;
        }
        footer {
            text-align: center;
            color: #111111;
            padding: 60px 0 48px 0;
        }
        :global(.rough-frame-svg) {
            overflow: visible;
        }
    </style>
</head>
<body>
<canvas class="paper-marks" aria-hidden="true"></canvas>
<section id="greeting">
    <h1>珍スポ研究室</h1>
    <div class="description" data-rough-bleed="8" data-rough-kind="intro">
       <p>珍スポ研究室とは、珍スポット（B級スポット）が好きな人たちが集まるコミュニティです。</p>
       <p>主にLINEオープンチャットで活動しています。</p>
    </div>
</section>
<section id="future-events" class="events-section">
    <h2>これからのオフ会</h2>
    <div class="event-list">
      {
			  futurePlans.map((plan) => (
          <PlanCard plan={{ key: plan.slug, ...plan.data}} />
        ))
      }
    </div>
</section>
<section id="sns" class="events-section">
  <h2>SNS</h2>
  <div class="sns-list">
    <a class="sns-button line-button rough-frame" href="https://line.me/ti/g2/o6s0F62sSXO5k_dkl6xukS_pzeEnu6_5WAAJ2w" target="_blank">
      <img src="/images/chinspot-kenkyu.png" width="48" height="48" alt="LINE|珍スポ研究室" />
      <div class="sns-content">
        <div class="sns-title">珍スポ研究室</div>
        <p>珍スポの情報を共有するLINEオープンチャットです。</p>
        <p>こちらがメインの活動場所になります。</p>
      </div>
    </a>
    <a class="sns-button line-button rough-frame" href="https://line.me/ti/g2/PZfs6bwr4EejequqSQYxW5Xc3zFotxYJqI3S0w" target="_blank">
      <img src="/images/chinspot-tanken_96x.webp" width="48" height="48" alt="LINE|珍スポ探検隊" />
      <div class="sns-content">
        <div class="sns-title">オフ会専用板(珍スポ探検隊)</div>
        <p>オフ会用LINEオープンチャットです。</p>
        <p>オフ会参加希望の方はお入りください。</p>
      </div>
    </a>
    <a class="sns-button mixi2-button rough-frame" href="https://mixi.social/communities/b7036707-043d-4ea1-b440-aee13e275ec1?r=yyboedslphls" target="_blank">
      <img src="/images/daibutsu_184x.jpg" width="48" height="48" alt="mixi2|珍スポ研究室" />
      <div class="sns-content">
        <div class="sns-title">珍スポ研究室</div>
        <p>珍スポの情報を共有するmixi2のグループです。</p>
      </div>
    </a>
    <a class="sns-button x-button rough-frame" href="https://x.com/chinspotcom" target="_blank">
      <img src="/images/chin_x.png" width="48" height="48" alt="X|珍スポ研究室" />
      <div class="sns-content">
        <div class="sns-title">珍スポ研究室</div>
        <p>@chinspotcom</p>
        <p>公式Xです。</p>
      </div>
    </a>
    <a class="sns-button instagram-button rough-frame" href="https://www.instagram.com/chinspotcom" target="_blank">
      <img src="/images/chin_x.png" width="48" height="48" alt="Instagram|珍スポ研究室" />
      <div class="sns-content">
        <div class="sns-title">珍スポ研究室</div>
        <p>@chinspotcom</p>
        <p>公式Instagramです。</p>
      </div>
    </a>
  </div>
</section>
<section id="passed-events" class="events-section">
    <h2>過去のオフ会</h2>
    <div class="event-list">
      {
        pastPlans.map((plan) => (
          <PlanCard plan={{ key: plan.slug, ...plan.data}} />
        ))
      }
    </div>
</section>
<section>
  <h2>管理人</h2>
  <ProfileCard />
</section>
<footer>
    <p>© 2024 珍スポ研究室</p>
</footer>
<script>
  import rough from 'roughjs';
  import { drawPaperMarks } from '../lib/PaperMarks';

  const SVG_NS = 'http://www.w3.org/2000/svg';
  const MAX_SEED = 2147483647;

  const randomBetween = (min: number, max: number) => (
    min + Math.random() * (max - min)
  );

  const randomSeed = () => Math.floor(randomBetween(1, MAX_SEED));

  type RoughPoint = [number, number];

  const getNumberData = (element: HTMLElement, key: string, fallback: number) => {
    const value = element.dataset[key];
    if (!value) {
      return fallback;
    }
    const parsed = Number(value);
    return Number.isFinite(parsed) ? parsed : fallback;
  };

  const createWobblyRectPoints = (
    x: number,
    y: number,
    width: number,
    height: number,
    wobble: number
  ) => {
    const points: RoughPoint[] = [];
    const right = x + width;
    const bottom = y + height;
    const horizontalSteps = Math.max(2, Math.ceil(width / 180));
    const verticalSteps = Math.max(2, Math.ceil(height / 120));
    const jitter = (value: number) => randomBetween(-value, value);

    for (let i = 0; i <= horizontalSteps; i += 1) {
      const progress = i / horizontalSteps;
      points.push([x + width * progress, y + jitter(wobble)]);
    }
    for (let i = 1; i <= verticalSteps; i += 1) {
      const progress = i / verticalSteps;
      points.push([right + jitter(wobble), y + height * progress]);
    }
    for (let i = horizontalSteps - 1; i >= 0; i -= 1) {
      const progress = i / horizontalSteps;
      points.push([x + width * progress, bottom + jitter(wobble)]);
    }
    for (let i = verticalSteps - 1; i > 0; i -= 1) {
      const progress = i / verticalSteps;
      points.push([x + jitter(wobble), y + height * progress]);
    }

    return points;
  };

  const getRoughFrameOptions = (width: number) => {
    const longEdgeScale = Math.min(1, Math.max(0.34, 680 / Math.max(width, 1)));

    return {
      bowing: randomBetween(0.35, 1.15) * longEdgeScale,
      disableMultiStroke: true,
      maxRandomnessOffset: randomBetween(0.45, 1.15),
      preserveVertices: true,
      roughness: randomBetween(0.75, 2.1),
      seed: randomSeed(),
      stroke: '#666666',
      strokeWidth: randomBetween(0.7, 1.1),
    };
  };

  const drawRoughFrame = (element: HTMLElement) => {
    const previous = element.querySelector(':scope > .rough-frame-svg');
    previous?.remove();

    const width = element.offsetWidth;
    const height = element.offsetHeight;
    if (width <= 0 || height <= 0) {
      return;
    }

    const bleed = getNumberData(element, 'roughBleed', 7);
    const svg = document.createElementNS(SVG_NS, 'svg');
    const viewWidth = width + bleed * 2;
    const viewHeight = height + bleed * 2;

    svg.classList.add('rough-frame-svg');
    svg.setAttribute('aria-hidden', 'true');
    svg.setAttribute('focusable', 'false');
    svg.setAttribute('viewBox', `0 0 ${viewWidth} ${viewHeight}`);
    svg.style.position = 'absolute';
    svg.style.inset = `${-bleed}px`;
    svg.style.width = `calc(100% + ${bleed * 2}px)`;
    svg.style.height = `calc(100% + ${bleed * 2}px)`;
    svg.style.pointerEvents = 'none';
    svg.style.zIndex = '3';

    const roughSvg = rough.svg(svg);
    const wobble = 0.3;

    const frame = roughSvg.polygon(
      createWobblyRectPoints(bleed, bleed, width, height, wobble),
      getRoughFrameOptions(width)
    );
    frame.querySelectorAll('path').forEach((path) => {
      path.setAttribute('stroke-linecap', 'round');
      path.setAttribute('stroke-linejoin', 'round');
    });
    svg.appendChild(frame);

    element.prepend(svg);
  };

  const redrawRoughFrames = () => {
    document.querySelectorAll<HTMLElement>('.rough-frame').forEach(drawRoughFrame);
  };

  let resizeFrame = 0;
  const scheduleRedraw = () => {
    if (resizeFrame) {
      cancelAnimationFrame(resizeFrame);
    }
    resizeFrame = requestAnimationFrame(() => {
      resizeFrame = 0;
      drawPaperMarks();
      redrawRoughFrames();
    });
  };

  const images = document.querySelectorAll('.event-list .plan img');
  images.forEach(img => {
    img.setAttribute('loading', 'lazy');
    img.setAttribute('decoding', 'async');
  });

  const randomizeImageTilts = () => {
    document.querySelectorAll<HTMLImageElement>('img').forEach((img) => {
      const angle = randomBetween(-0.25, 0.25);
      img.style.transform = `rotate(${angle}deg)`;
    });
  };

  drawPaperMarks();
  redrawRoughFrames();
  randomizeImageTilts();
  window.addEventListener('resize', scheduleRedraw);
  window.addEventListener('load', scheduleRedraw, { once: true });
</script>
</body>
</html>
